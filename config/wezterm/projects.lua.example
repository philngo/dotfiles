-- Machine-specific project workspaces for Wezterm (Cmd-p selector).
-- These are merged with base projects defined in wezterm.lua.
-- Copy to projects.lua and edit:
--   cp projects.lua.example projects.lua
--
-- Each entry defines a workspace with:
--   id    — workspace name (shown in status bar)
--   label — display name in selector
--   cwd   — working directory
--   root  — (optional) jj repo root, when cwd is a subdirectory of the repo.
--           jj workspace discovery appends -N to root and preserves the relative
--           subdir. E.g. root=~/dev/Foo, cwd=~/dev/Foo/api discovers ~/dev/Foo-1/api
--   args  — (optional) command to run on launch
--   setup — (optional) named layout string ("dev") or custom function(initial_pane, cwd)

return {
	-- Simple project (cwd is the repo root):
	-- {
	-- 	id = "myproject",
	-- 	label = "My Project",
	-- 	cwd = os.getenv("HOME") .. "/dev/myproject",
	-- 	setup = "dev",
	-- },
	--
	-- Monorepo subdirectory (jj workspaces discovered via root):
	-- {
	-- 	id = "myproject-api",
	-- 	label = "My Project API",
	-- 	root = os.getenv("HOME") .. "/dev/myproject",
	-- 	cwd = os.getenv("HOME") .. "/dev/myproject/api",
	-- 	setup = "dev",
	-- },
}
