#!/usr/bin/env bash
# Called by Claude Code Notification hook on permission_prompt events.
# Sends a macOS notification and writes the workspace so WezTerm auto-focuses on switch.
set -euo pipefail

# Read hook input from stdin
input=$(cat)
title=$(echo "$input" | jq -r '.title // "Claude Code"')
message=$(echo "$input" | jq -r '.message // "Needs attention"')

# Send notification via osascript (terminal-notifier is throttled on macOS 26+)
osascript -e "display notification \"$message\" with title \"$title\" sound name \"default\"" &

# Write workspace so WezTerm auto-focuses on switch
if [ -n "${WEZTERM_PANE:-}" ]; then
    command -v wezterm &>/dev/null || exit 0
    workspace=$(wezterm cli list --format json 2>/dev/null \
        | jq -r --arg pane "$WEZTERM_PANE" '.[] | select(.pane_id == ($pane | tonumber)) | .workspace' 2>/dev/null || true)
    if [ -n "$workspace" ]; then
        mkdir -p ~/.local/state/wezterm
        echo "$workspace" > ~/.local/state/wezterm/switch-workspace
    fi
fi
